### Name: GeneralizedUmatrixGPU
### Title: Generalized U-Matrix on GPU for Projection Methods published in
###   [Thrun/Ultsch, 2020]
### Aliases: GeneralizedUmatrixGPU getUmatrix4Projection
### Keywords: visualization U-Matrix Umatrix GeneralizedUmatrixGPU
###   GeneralizedUmatrix
### ** Examples
library(GeneralizedUmatrix)
data("Chainlink")
Data=Chainlink$Data
Cls=Chainlink$Cls
InputDistances=as.matrix(dist(Data))
res=cmdscale(d=InputDistances, k = 2, eig = TRUE, add = FALSE, x.ret = FALSE)
ProjectedPoints=as.matrix(res$points)
