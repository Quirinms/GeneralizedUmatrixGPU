PKG_CPPFLAGS += -DRCPP_PARALLEL_USE_TBB=1
PKG_CPPFLAGS += $(shell '${R_HOME}/bin${R_ARCH_BIN}/Rscript.exe' -e 'RcppParallel::CxxFlags()')
PKG_LIBS += $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS) $(shell '${R_HOME}/bin${R_ARCH_BIN}/Rscript.exe' \ -e 'RcppParallel::RcppParallelLibs()')
PKG_CPPFLAGS='-IC:\AMDAPPSDK\30\include'
PKG_LIBS='-LC:\AMDAPPSDK\30\lib\x64' -lOpenCL
all: $(SHLIB)
